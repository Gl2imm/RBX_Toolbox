class RbxSignature:
    PublicKeyId : int
    SignatureType : RbxSignatureType
    Value : Array_1[int]


class RbxSignatureType(typing.SupportsInt):
    @typing.overload
    def __init__(self, value : int) -> None: ...
    @typing.overload
    def __init__(self, value : int, force_if_true: bool) -> None: ...
    def __int__(self) -> int: ...
    
    # Values:
    Ed25519 : RbxSignatureType # 0


