import typing
from RobloxFiles.BinaryFormat import IBinaryFileChunk, BinaryRobloxFileReader, BinaryRobloxFileWriter
from System.Collections.Generic import List_1, Dictionary_2
from System.Text import StringBuilder
from RobloxFiles import PropertyType
from System import Array_1

class INST(IBinaryFileChunk):
    def __init__(self) -> None: ...
    @property
    def ClassIndex(self) -> int: ...
    @ClassIndex.setter
    def ClassIndex(self, value: int) -> int: ...
    @property
    def ClassName(self) -> str: ...
    @ClassName.setter
    def ClassName(self, value: str) -> str: ...
    @property
    def IsService(self) -> bool: ...
    @IsService.setter
    def IsService(self, value: bool) -> bool: ...
    @property
    def NumObjects(self) -> int: ...
    @NumObjects.setter
    def NumObjects(self, value: int) -> int: ...
    @property
    def ObjectIds(self) -> List_1[int]: ...
    @ObjectIds.setter
    def ObjectIds(self, value: List_1[int]) -> List_1[int]: ...
    @property
    def RootedServices(self) -> List_1[bool]: ...
    @RootedServices.setter
    def RootedServices(self, value: List_1[bool]) -> List_1[bool]: ...
    def Load(self, reader: BinaryRobloxFileReader) -> None: ...
    def Save(self, writer: BinaryRobloxFileWriter) -> None: ...
    def ToString(self) -> str: ...
    def WriteInfo(self, builder: StringBuilder) -> None: ...


